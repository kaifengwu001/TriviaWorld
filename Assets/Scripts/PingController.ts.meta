  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">PingController – drives the expanding world-scan ping shells</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Clones the ping material onto the target visuals and animates per-ping radius/alpha uniforms each frame. Call emitBurst(origin) to fire a series of shells.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Asset.Material pingMaterial {"hint":"Ping scan graph material. Cloned at runtime and assigned to every target visual so the asset itself is never mutated."}'
    - '// @input Component.RenderMeshVisual[] targetVisuals {"hint":"Render visuals that should display the ping effect (e.g. the World Mesh visual and the ground-plane fallback quad)."}'
    - '// @input SceneObject headObject {"hint":"Scene object whose world position is the default ping origin (player head / camera). Used by the editor tap test."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Tuning</span>"}'
    - '// @input float pingSpeed = 250 {"hint":"Expansion speed of each shell, in cm per second"}'
    - '// @input float maxRadius = 450 {"hint":"Radius (cm) at which a ping has fully faded out and is recycled"}'
    - '// @input float bandThickness = 12 {"hint":"Sharpness of the leading (outer) edge (cm). Small = crisp wavefront."}'
    - '// @input float trailLength = 90 {"hint":"How far the glow trails behind the wavefront on the inner side (cm). Large = long comet tail."}'
    - '// @input float trailFalloff = 2 {"hint":"Tail shaping power. >1 concentrates brightness near the front and fades the tail out smoothly."}'
    - '// @input float burstCount = 3 {"hint":"Number of shells emitted per emitBurst() call"}'
    - '// @input float burstIntervalSec = 0.15 {"hint":"Seconds between successive shells within a burst"}'
    - '// @input float burstBrightnessFalloff = 0.5 {"hint":"Brightness multiplier applied to each successive shell in a burst (0.5 = each followup is half as bright as the previous)."}'
    - '// @input vec4 pingColor = {0.3,0.8,1,1} {"hint":"Color of the ping band (RGB), alpha scales overall intensity"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Debug</span>"}'
    - '// @input bool debugStaticRing {"hint":"Force one always-on ring at debugRadius (ignores triggers/timer) to verify the shader + material wiring"}'
    - '// @input float debugRadius = 150 {"hint":"Radius (cm) of the forced debug ring"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
