  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">PrayerGestureBehavior – detects the 双手合十 prayer pose</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Requires both hands tracked, palms close + facing each other + fingers pointing up. On detection it shows a Text notification (placeholder for a future animation).</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Component.Text notificationText {"hint":"Text component shown briefly when the prayer pose is detected"}'
    - '// @input string notificationMessage = "Prayer detected" {"hint":"Message displayed in the notification text"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Detection thresholds</span>"}'
    - "// @input float palmDistanceCm = 8 {\"hint\":\"Max distance (cm) between the two palm centers to count as 'together'\"}"
    - '// @input float fingersUpPitchDeg = 30 {"hint":"Min palm pitch angle (deg) for each hand; >0 means fingers point up"}'
    - '// @input float palmsFacingDot = 0.5 {"hint":"Min dot product of the two palm normals; closer to +1 = more directly facing each other (palms-together reads ~0.7-0.8)"}'
    - '// @input float holdFrames = 3 {"hint":"Number of consecutive frames the pose must hold before firing"}'
    - '// @input float cooldownSec = 2 {"hint":"Seconds to wait after a detection before it can fire again"}'
    - '// @input float notificationDurationSec = 2.5 {"hint":"Seconds the notification stays visible"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Debug</span>"}'
    - "// @input bool debugMode {\"hint\":\"Continuously write hand count + every threshold's status to the notification Text (keeps it always visible)\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
