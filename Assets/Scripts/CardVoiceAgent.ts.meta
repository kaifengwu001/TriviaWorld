  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Card Voice Agent (Gemini Live, two-way)</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Conversational agent with mic input. Tap a card and it speaks an extra fact, then answers spoken follow-ups. Does NOT run in the simulator — test on device with internet.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Setup (drag from the RemoteServiceGatewayExamples prefab)"}'
    - "// @input SceneObject websocketRequirementsObj {\"hint\":\"The 'Websocket requirements' SceneObject. Enabled on launch so the gateway WebSocket can connect.\"}"
    - "// @input AssignableType dynamicAudioOutput {\"hint\":\"A DynamicAudioOutput that plays the agent's voice. Use a DEDICATED one (not the same instance as WelcomeVoice) so the two sessions don't fight over playback.\"}"
    - "// @input AssignableType_1 microphoneRecorder {\"hint\":\"The MicrophoneRecorder that captures the user's voice for follow-up questions.\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Speech"}'
    - '// @input string voice = "Leda" {"widget":"combobox", "values":[{"label":"Leda", "value":"Leda"}, {"label":"Puck", "value":"Puck"}, {"label":"Charon", "value":"Charon"}, {"label":"Kore", "value":"Kore"}, {"label":"Fenrir", "value":"Fenrir"}, {"label":"Aoede", "value":"Aoede"}, {"label":"Orus", "value":"Orus"}, {"label":"Zephyr", "value":"Zephyr"}]}'
    - '// @input string persona {"hint":"System instruction / persona for the conversational agent.", "widget":"text_area"}'
    - "// @input string model = \"gemini-live-2.5-flash\" {\"hint\":\"Gemini Live model id (no 'models/' prefix — it's added automatically). Supported: gemini-live-2.5-flash, gemini-2.0-flash-live-preview-04-09, gemini-live-2.5-flash-preview-native-audio\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Logging"}'
    - // @input bool enableLogging = true
    - '// @ui {"widget":"group_end"}'
