  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">WorldMeshFallback – chooses World Mesh vs ground-plane surface</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Enables the World Mesh visual when reconstruction has faces; otherwise shows a ground quad placed at the detected (or default) floor height.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Component.RenderMeshVisual worldMeshVisual {"hint":"World Mesh RenderMeshVisual (driven by WorldRenderObjectProvider)"}'
    - '// @input SceneObject groundPlane {"hint":"Ground-plane quad used as the fallback ping surface"}'
    - '// @input SceneObject headObject {"hint":"Scene object used as the head/camera reference for floor detection"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Tuning</span>"}'
    - '// @input float defaultFloorOffset = -120 {"hint":"Fallback floor offset below the head (cm, negative = below). Used when no floor hit is found."}'
    - '// @input bool keepGroundWithMesh {"hint":"Keep the ground plane enabled even when the World Mesh is available (covers mesh holes)"}'
    - '// @input bool assumeMeshOnDevice = true {"hint":"On-device, treat the World Mesh as available even when faceCount reads 0. faceCount is reliable in the editor but often reports 0 on Spectacles while the mesh is still scanning/rendering. Disable only for non-Spectacles builds."}'
    - '// @input float checkIntervalSec = 1 {"hint":"How often (seconds) to re-evaluate World Mesh availability and floor height"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Debug</span>"}'
    - '// @input Component.Text debugText {"hint":"Continuously write World Mesh status (faceCount, chosen surface, etc.) to this Text"}'
    - '// @input bool debugMode {"hint":"Enable writing the live status readout to debugText"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
