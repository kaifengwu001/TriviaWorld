  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">MapViewport – holodeck map table (UV pan/zoom under a fixed feathered crop)</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Single fixed mesh. Material must expose mapTex / uvOffset (vec2) / uvScale (vec2). The feathered crop mask is constant in the graph.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Component.RenderMeshVisual tableVisual {"hint":"OPTIONAL pre-made RenderMeshVisual of the table pane. Leave empty to BUILD a quad by code on this object. If set, its material is cloned."}'
    - '// @input Asset.Material tableMaterial {"hint":"Table material (the graph exposing mapTex / uvOffset / uvScale + a fixed crop mask). Required when the table is built by code; cloned at runtime."}'
    - '// @input float tableSizeCm = 60 {"hint":"Edge length (cm) of the code-built table quad. Ignored if a tableVisual is assigned. Match GlobeView.tableSizeCm."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Zoom limits (uvScale within a level)</span>"}'
    - '// @input float minUvScale = 0.34 {"hint":"Smallest uvScale allowed while zoomed into a level (shows the least area / most detail). The controller lowers this at runtime (via setMinUvScale) so its deeper per-level step-in thresholds are reachable; this inspector value is just the authored default/floor."}'
    - "// @input float maxUvScale = 1 {\"hint\":\"Largest uvScale (1 = the whole LOD texture fills the pane = the level's home framing). Above this the controller should step out a LOD.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Transitions</span>"}'
    - '// @input float fadeSec = 0.45 {"hint":"Seconds for the show/hide table fade and the per-LOD crossfade."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
