  InputLines:
    - "// @ui {\"widget\":\"label\", \"label\":\"<span style=\\\"color: #60A5FA;\\\">CardMarkerLayer – textured card markers on the globe + map table</span><br/><span style=\\\"color: #94A3B8; font-size: 11px;\\\">One marker per CardStore card, scattered around its city, merged when close in-scene, clipped to the table's visible circle, persistent through every zoom + dive.</span>\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input AssignableType globeController {"hint":"The GlobeController that owns the globe/table state machine. If unset, global.globeController is used."}'
    - "// @input Asset.Material markerMaterial {\"hint\":\"Unlit transparent material for the marker quad (cloned at runtime; its baseTex is replaced by Marker Texture). Falls back to a clone of the globe's material if unset.\"}"
    - '// @input Asset.Texture markerTexture {"hint":"The marker icon texture (drawn on a camera-billboarded quad)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Placement</span>"}'
    - "// @input float scatterRangeMiles = 5 {\"hint\":\"Radius (miles) of the disk around a city's center that its cards are scattered in. Each card's spot is random but STABLE (seeded by its id).\"}"
    - '// @input string[] scatterOverrideCities {"hint":"City names (matched case-insensitively to City Data) that override the default Scatter Range Miles. Pair each entry with the same index in Scatter Override Miles."}'
    - '// @input float[] scatterOverrideMiles {"hint":"Per-city scatter radius (miles), paired by index with Scatter Override Cities. A city listed here uses this radius instead of the default Scatter Range Miles."}'
    - '// @input float mergeDistanceCm = 4 {"hint":"Markers closer than this IN-SCENE distance (cm) merge into one marker at their average position. Never merges across cities."}'
    - "// @input bool avoidOcean = true {\"hint\":\"Keep scattered markers OFF the ocean by re-drawing a card's spot until it lands on land (uses the baked per-city water mask in waterMask.ts). Re-drawing stays seeded by the card id, so positions are still stable.\"}"
    - '// @input float tableLiftCm = 1.5 {"hint":"How far (cm) markers float above the ACTIVE surface — the globe AND the table use the same constant lift, so the dive handoff is height-continuous (markers never rise away as the globe scales up)."}'
    - "// @input float visibleCircleFraction = 0.95 {\"hint\":\"Radius of the table's visible (feathered) circle as a fraction of its half-size. Markers past it disappear and reappear when panned back in.\"}"
    - "// @input bool alwaysShowCityMarkers = true {\"hint\":\"In OVERVIEW, always show a marker at each city's center even if it has no cards (keeps the 3-city minimum).\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Visuals</span>"}'
    - '// @input float markerSizeCm = 3 {"hint":"Marker quad size (cm). Constant world size; markers billboard toward the camera."}'
    - '// @input float countTextSize = 24 {"hint":"Font size (points) of the merged-count label drawn over the marker."}'
    - '// @input float countTextHeight {"hint":"Vertical position of the count label relative to the marker, in fractions of the marker size (0 = centered on the icon, +0.5 = half a marker-height up, negative = down)."}'
    - '// @input float countTextDepth = 0.2 {"hint":"Depth offset of the count label toward the viewer, in fractions of the marker size (+ = closer to the camera so the label renders in front of the icon, - = behind)."}'
    - '// @input vec4 countTextColor = {1,1,1,1} {"hint":"Color (RGBA) of the merged-count label."}'
    - "// @input float highlightScale = 1.35 {\"hint\":\"Scale multiplier applied to a city's markers while the user gazes at it in OVERVIEW (mirrors the old pin highlight).\"}"
    - '// @input float markerRenderOrder = 500 {"hint":"Render order for the marker quads (count text draws one above). Keep above the globe/table so markers are never z-fought away."}'
    - "// @input float billboardDeadzoneDeg = 12 {\"hint\":\"Rotational DEADZONE (degrees) for each marker's yaw billboard: a marker only re-orients once its facing toward the camera has changed by more than this. Generous values (10-25) skip the per-frame quat write while the view barely moves. 0 = re-orient every frame.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
