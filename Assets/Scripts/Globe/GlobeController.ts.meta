  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">GlobeController – guided globe -> city-zoom state machine</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Wires gaze/pinch input to globe aim+zoom, the dock crossfade, and table pan/zoom/LOD. Alignment is math-driven from cityBounds.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Components</span>"}'
    - '// @input AssignableType globeView {"hint":"The globe (rotate-to-aim + scale-to-zoom, hidden while docked)."}'
    - '// @input AssignableType_1 mapViewport {"hint":"The holodeck map table (UV pan/zoom under a fixed feathered crop)."}'
    - '// @input AssignableType_2 cityData {"hint":"CityData component that resolves geo bounds + imported map textures."}'
    - "// @input AssignableType_3[] markers {\"hint\":\"OPTIONAL pre-placed markers (one per city). Leave empty to AUTO-CREATE + place them by code from each city's lat/lng.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Markers (auto-created)</span>"}'
    - '// @input bool autoCreateMarkers = true {"hint":"Create + place a marker per city from its lat/lng (parented to the globe). Turn off to use only the markers assigned above."}'
    - "// @input Asset.ObjectPrefab markerPrefab {\"hint\":\"OPTIONAL prefab instantiated as each auto-created marker's visual. If empty, markers are created as logic-only (invisible) objects.\"}"
    - '// @input float markerSurfaceOffset = 1.04 {"hint":"How far above the globe surface to place markers, as a fraction of the globe radius (1 = on the surface)."}'
    - '// @input float markerScale = 1 {"hint":"Uniform local scale applied to each auto-created marker object."}'
    - "// @input float textureLonOffsetDeg {\"hint\":\"Longitude offset in degrees added to every city before placing its marker AND aiming the globe. Use this to line cities up with the globe base texture when the texture can't be shifted in Lens Studio (+ rotates cities east, - west).\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Scene</span>"}'
    - '// @input SceneObject cameraObject {"hint":"Camera/head object, used for gaze selection and to size pan deltas."}'
    - "// @input SceneObject tableObject {\"hint\":\"The table's transform object; its right/up axes convert hand drags into UV pan. Defaults to the MapViewport's object if unset.\"}"
    - "// @input Component.Text labelText {\"hint\":\"Optional Text label showing the current LOD's name.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Tuning</span>"}'
    - '// @input float approachSec = 1.1 {"hint":"Seconds for the OVERVIEW->dock approach tween."}'
    - '// @input float crossfadeSec = 0.5 {"hint":"Seconds for the globe-out / table-in crossfade."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Dive feel (per-channel bias)</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">One knob per channel, range -1..+1.<br/><b>0</b> = smooth ease-in-out (natural). <b>+1</b> = front-loaded (fast start, gentle finish). <b>-1</b> = back-loaded (slow start, fast finish). Magnitude = strength.</span>"}'
    - '// @input float positionBias {"hint":"POSITION feel: how the top tip travels to the table. +1 darts over early then eases in; -1 creeps then rushes.", "widget":"slider", "min":-1, "max":1, "step":0.05}'
    - '// @input float rotationBias {"hint":"ROTATION feel: how the city swings up to the top. +1 snaps the turn early; -1 holds then whips around.", "widget":"slider", "min":-1, "max":1, "step":0.05}'
    - '// @input float scaleBias {"hint":"SCALE feel: how the zoom-into-the-surface accelerates. +1 grows fast then settles; -1 eases in then surges.", "widget":"slider", "min":-1, "max":1, "step":0.05}'
    - "// @input float fadeBias {\"hint\":\"FADE feel: the globe's alpha out (on dock) / in (on return).\", \"widget\":\"slider\", \"min\":-1, \"max\":1, \"step\":0.05}"
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Speed = how fast a channel finishes RELATIVE to the dive time. 1 = uses the full dive; 2 = done in half the time (then holds); &lt;1 = slower. Bias only reshapes a channel; speed is what makes it finish sooner.</span>"}'
    - '// @input float positionSpeed = 1 {"hint":"POSITION speed multiplier (1 = full dive duration, higher = arrives sooner).", "widget":"slider", "min":0.25, "max":5, "step":0.05}'
    - '// @input float rotationSpeed = 2 {"hint":"ROTATION speed multiplier (1 = full dive duration, higher = swings up sooner). Raise this if the turn feels too slow even at max bias.", "widget":"slider", "min":0.25, "max":5, "step":0.05}'
    - '// @input float scaleSpeed = 1 {"hint":"SCALE speed multiplier (1 = full dive duration, higher = zooms in sooner).", "widget":"slider", "min":0.25, "max":5, "step":0.05}'
    - '// @input float fadeSpeed = 1 {"hint":"FADE speed multiplier (1 = full dive duration, higher = fades sooner).", "widget":"slider", "min":0.25, "max":5, "step":0.05}'
    - '// @input bool fadeOutGlobe = true {"hint":"Fade the globe out as it docks (and back in on return). Turn OFF to keep the globe fully visible at the dock pose, so you can verify the selected location ends up on TOP with the correct orientation."}'
    - '// @input float gazeHalfAngleDeg = 12 {"hint":"Cosine-threshold half-angle (degrees) of the gaze cone for marker selection."}'
    - '// @input float tableSizeCm = 60 {"hint":"On-screen table size in cm (matches GlobeView.tableSizeCm). Scales hand drags into UV pan."}'
    - '// @input float panSpeed = 0.3 {"hint":"Pan speed multiplier for one-hand drag -> uvOffset."}'
    - '// @input float zoomSpeed = 1 {"hint":"Two-hand pinch zoom sensitivity (>1 = faster). Applies to both hand and two-finger touch zoom."}'
    - '// @input float lodEnterZoom = 0.7 {"hint":"uvScale a newly-entered deeper LOD loads at (1 = fully zoomed out/home; lower = more zoomed in). ~0.7 leaves room to pan and zoom right after a step-in, and makes the step happen a bit later/deeper on the previous level."}'
    - '// @input float handRotateSpeed = 0.03 {"hint":"Globe rotation gain for a one-hand pinch-drag in OVERVIEW (radians of spin per cm of smoothed hand movement)."}'
    - '// @input float globeRightingSpeed = 6 {"hint":"How strongly the globe springs back to upright (poles vertical) after you release a drag in OVERVIEW. Higher = snappier; 0 disables self-righting and lets the globe stay tilted."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Touch input</span>"}'
    - '// @input float touchRotateSpeed = 3 {"hint":"Globe rotation speed for a one-finger drag in OVERVIEW (radians per full-screen drag)."}'
    - '// @input float touchPanGain = 1.2 {"hint":"Table pan gain for a one-finger drag in DOCKED (multiplies the normalized screen delta)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
