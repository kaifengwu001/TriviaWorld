  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Recommendation Voice Agent (Gemini Live + mic + select_card)</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Presents the three recommendation cards and lets the user pick one by voice. Engaged by the topic panel on Start. Does NOT run in the simulator — test on device with internet.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Setup (can share the WelcomeVoice objects — never run at once)"}'
    - "// @input SceneObject websocketRequirementsObj {\"hint\":\"The 'Websocket requirements' SceneObject. Enabled on engage so the gateway WebSocket can connect.\"}"
    - "// @input AssignableType dynamicAudioOutput {\"hint\":\"A DynamicAudioOutput that plays this agent's voice (can be the same one WelcomeVoice uses).\"}"
    - "// @input AssignableType_1 microphoneRecorder {\"hint\":\"A MicrophoneRecorder that captures the user's speech (can be the same one WelcomeVoice uses).\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Speech"}'
    - '// @input string voice = "Aoede" {"widget":"combobox", "values":[{"label":"Leda", "value":"Leda"}, {"label":"Puck", "value":"Puck"}, {"label":"Charon", "value":"Charon"}, {"label":"Kore", "value":"Kore"}, {"label":"Fenrir", "value":"Fenrir"}, {"label":"Aoede", "value":"Aoede"}, {"label":"Orus", "value":"Orus"}, {"label":"Zephyr", "value":"Zephyr"}]}'
    - '// @input string persona {"hint":"System instruction / persona for the recommendation presenter.", "widget":"text_area"}'
    - "// @input string model = \"gemini-live-2.5-flash\" {\"hint\":\"Gemini Live model id (no 'models/' prefix). Supported: gemini-live-2.5-flash, gemini-2.0-flash-live-preview-04-09, gemini-live-2.5-flash-preview-native-audio\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
