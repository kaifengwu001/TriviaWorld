  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">RecommendationCards – fly-in cards → pinch-select → direction arrow</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Asset.ObjectPrefab cardPrefab {"hint":"The PremadeCard prefab, instantiated once per recommendation card."}'
    - '// @input SceneObject cameraObject {"hint":"Camera object – used for row placement, billboarding, and head-locking the arrow."}'
    - '// @input Asset.ObjectPrefab arrowPrefab {"hint":"The white arrow prefab (Arrowgeo.obj with an unlit white material)."}'
    - '// @input Asset.Texture[] cardImages {"hint":"Three card images, in order: 0 Art Festival, 1 Reality Hack, 2 Snap Lounge."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Arrow direction (per card)</span>"}'
    - "// @input float[] cardHeadings = {-40,0,40} {\"hint\":\"Per-card heading in degrees (yaw about world-up, relative to the user's forward at selection). One per card; the arrow points along this direction.\"}"
    - "// @input float[] cardPitches = {0,0,0} {\"hint\":\"Per-card pitch in degrees (positive tilts the arrow UP, e.g. toward an upper floor). One per card. Requires 'Keep arrow flat' off.\"}"
    - "// @input float[] cardDistancesM = {100,100,100} {\"hint\":\"Per-card distance in METRES. Drives how far out the world-fixed target sits AND the 'XX m' label beneath the arrow. One per card.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Distance label</span>"}'
    - "// @input vec4 distanceLabelColor = {1,1,1,1} {\"hint\":\"Colour of the 'XX m' text beneath the arrow.\"}"
    - "// @input float distanceLabelSize = 64 {\"hint\":\"Font size of the 'XX m' label.\"}"
    - "// @input bool distanceLabelBold = true {\"hint\":\"Bold the 'XX m' label (faux-bold via a same-colour outline that thickens the strokes).\"}"
    - "// @input float distanceLabelDropCm = 2 {\"hint\":\"How far (cm) beneath the arrow the 'XX m' label sits. Smaller = closer to the arrow.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Tuning</span>"}'
    - '// @input bool tuningMode {"hint":"When ON, skip the card flow and spawn all 3 arrows at once at launch so you can tune cardHeadings / cardPitches / cardDistancesM live in the inspector."}'
    - "// @input float[] tuningScreenX = {-0.5,0,0.5} {\"hint\":\"Horizontal FoV fractions (-1 left .. +1 right) used to spread the 3 tuning arrows so they don't overlap. One per card.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Layout</span>"}'
    - '// @input float rowDepthCm = 60 {"hint":"Distance (cm) in front of the user where the card row settles."}'
    - '// @input float rowRiseCm {"hint":"Vertical offset (cm) of the card row relative to eye level."}'
    - '// @input float cardSpacingCm = 22 {"hint":"Horizontal gap (cm) between adjacent cards in the row."}'
    - '// @input float cardImageWidthCm = 13.3 {"hint":"Displayed image width (cm) for each card. The picture, caption wrap, auto-fit border, and collider all flow from this — the card stays at world scale 1. (This is the correct knob for a premade card; do NOT scale the whole card.)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Timing (seconds)</span>"}'
    - '// @input float flyInDuration = 0.8 {"hint":"Fly-in animation duration."}'
    - '// @input float selectHoldSeconds = 3 {"hint":"How long the selected card stays before turning into the arrow."}'
    - '// @input float arrowLifetimeSeconds = 10 {"hint":"How long the arrow stays before dissipating."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Arrow placement</span>"}'
    - '// @input float arrowScreenY = -0.6 {"hint":"Vertical FoV fraction for the arrow: -1 bottom .. +1 top. Keep low to avoid blocking the view."}'
    - '// @input float arrowDistanceCm = 100 {"hint":"Distance (cm) in front of the head where the arrow sits. Larger = farther away and smaller on screen."}'
    - "// @input float arrowSizeCm = 8 {\"hint\":\"On-screen arrow size: its largest dimension in centimetres. Auto-scaled from the mesh bounds, so it's predictable regardless of the imported model's native units.\"}"
    - "// @input float arrowYawOffsetDeg {\"hint\":\"Yaw correction (deg) for the imported arrow mesh's natural axis. Tune so the arrow tip points along the heading.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - // @input bool enableLogging
