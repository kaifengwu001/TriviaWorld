  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">BubbleMesh – morphs a Perlin blob into a rounded rectangle</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Builds a runtime mesh on its own RenderMeshVisual and interpolates blob &lt;-&gt; rounded rect by the progress value (0..1).</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Material</span>"}'
    - "// @input Asset.Material baseMaterial {\"hint\":\"Base material cloned per-bubble. baseColor is overwritten with this bubble's color. Use an unlit, two-sided material for a flat colored shape.\"}"
    - "// @input vec4 color = {0.2,0.6,1,1} {\"hint\":\"Fill color (RGBA) applied to the cloned material's baseColor\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Ring</span>"}'
    - "// @input float innerFraction = 0.1 {\"hint\":\"Ring band thickness as a fraction of the radius (the prototype's SUB_FRACTION). The bubble is a hollow ring: the filled band runs from the outer rim down to a radius*(1-fraction) inner rim, and the two rims undulate independently. Small = thin rim ring; 1 = solid disc.\"}"
    - "// @input float fillOpacity = 0.9 {\"hint\":\"Opacity multiplier applied to the ring fill (needs a translucent material to show; an opaque material stays solid). Matches the prototype's 0.9 fill opacity.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Blob Shape</span>"}'
    - "// @input float radius = 4 {\"hint\":\"Blob radius in cm (local). Drives the bubble's resting size before morphing.\"}"
    - '// @input float noiseScale = 0.48 {"hint":"Perlin sampling scale – higher values give more, tighter wobbles around the rim"}'
    - '// @input float distortion = 4 {"hint":"How far the noise pushes the rim in/out, in reference-radius units"}'
    - '// @input float numPoints = 48 {"hint":"Total outline points (shared by blob and rect). Corner-weighting means this can be low while corners stay smooth; raise for an even rounder blob."}'
    - '// @input float cornerWeight {"hint":"How strongly rounded-rect points pack into the corners vs. straight edges (1 = by length only). Higher lets you lower Num Points further while keeping smooth corners."}'
    - '// @input float referenceRadius {"hint":"Reference radius used to normalize distortion (matches the source example)"}'
    - '// @input float undulateSpeed = 0.15 {"hint":"Wobble animation speed (noise offset advanced per second)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Target Rounded Rectangle</span>"}'
    - '// @input float targetWidth = 12 {"hint":"Target rectangle width in cm. Arbitrary; corner radius stays fixed."}'
    - '// @input float targetHeight = 8 {"hint":"Target rectangle height in cm. Arbitrary aspect ratio is supported."}'
    - '// @input float targetCornerRadius = 2 {"hint":"Fixed corner radius in cm (clamped to half the shorter side)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Morph</span>"}'
    - '// @input float progress {"hint":"Debug morph amount: 0 = blob, 1 = rounded rectangle"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
