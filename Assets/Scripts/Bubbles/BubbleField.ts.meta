  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">BubbleField – spawns and drives a field of morphing bubbles</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Creates N BubbleMesh children with assorted colors/sizes and animates the blob &lt;-&gt; rounded-rect morph for testing.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Material & Colors</span>"}'
    - '// @input Asset.Material baseMaterial {"hint":"Base material cloned onto every bubble. Use an unlit, two-sided material."}'
    - '// @input vec4[] palette = {} {"hint":"Color palette (RGBA). Bubbles cycle through these; if empty, random colors are used."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Spawning (cylindrical pipe around the player)</span>"}'
    - '// @input float bubbleCount = 12 {"hint":"Number of bubbles to spawn"}'
    - "// @input float minDistance = 80 {\"hint\":\"Minimum horizontal distance (cm) from the field origin a bubble can spawn — the pipe's inner wall.\"}"
    - "// @input float maxDistance = 220 {\"hint\":\"Maximum horizontal distance (cm) from the field origin a bubble can spawn — the pipe's outer wall.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Wavefront spawn-out</span>"}'
    - '// @input bool spawnOnWavefront = true {"hint":"Pop bubbles into being as the ping wavefront reaches each one (call spawnWave(origin), e.g. forwarded by PingCardSpawner) instead of spawning them all at start. Off = legacy behaviour: all bubbles exist from the very beginning."}'
    - "// @input AssignableType pingController {\"hint\":\"PingController whose pingSpeed times each bubble's reveal so they appear with the visible ping. Optional — falls back to Wavefront Speed Override.\"}"
    - '// @input float wavefrontSpeedOverride {"hint":"Override the wavefront speed (cm/s). 0 = read pingSpeed from the linked PingController (recommended so reveals match the visible ping)."}'
    - '// @input float revealOffsetSec {"hint":"Extra seconds added to every bubble reveal. Nudge to pop bubbles right ON the band vs slightly behind it."}'
    - "// @input float revealPopDuration = 0.5 {\"hint\":\"Seconds of the bubble's pop-in scale animation when it is revealed on the wavefront.\"}"
    - '// @input bool allowRespawn {"hint":"Allow a later wave to clear the previous bubbles and spawn again. Off = the first wave wins and later calls are ignored."}'
    - '// @input float floorHeight = -50 {"hint":"Floor height (cm, local Y) — the bottom of the spawn pipe. May be negative (below the origin)."}'
    - '// @input float ceilingHeight = 100 {"hint":"Ceiling height (cm, local Y) — the top of the spawn pipe."}'
    - '// @input float radiusMin = 3 {"hint":"Minimum blob radius (cm)"}'
    - '// @input float radiusMax = 6 {"hint":"Maximum blob radius (cm)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Target Rounded Rectangles</span>"}'
    - '// @input float targetWidthMin = 8 {"hint":"Minimum target rectangle width (cm)"}'
    - '// @input float targetWidthMax = 16 {"hint":"Maximum target rectangle width (cm)"}'
    - '// @input float targetHeightMin = 6 {"hint":"Minimum target rectangle height (cm)"}'
    - '// @input float targetHeightMax = 10 {"hint":"Maximum target rectangle height (cm)"}'
    - '// @input float targetCornerRadius = 2 {"hint":"Fixed corner radius (cm), kept constant regardless of size/aspect"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Shape Detail</span>"}'
    - '// @input float numPoints = 64 {"hint":"Points per RIM (the ring mesh uses 2x for outer + inner). On the rounded rect every point goes to the corners (none on the straight edges), so each corner gets ~numPoints/4 points. Raise for denser corners."}'
    - '// @input float noiseScale = 0.48 {"hint":"Perlin sampling scale for the blob rim"}'
    - '// @input float distortion = 4 {"hint":"Blob rim distortion amount"}'
    - '// @input float undulateSpeed = 0.15 {"hint":"Wobble animation speed"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Ring</span>"}'
    - "// @input float innerFraction = 0.1 {\"hint\":\"BLOB ring thickness as a fraction of the radius (the prototype's SUB_FRACTION). Varies per bubble with the radius. Small = thin rim ring; 1 = solid disc.\"}"
    - '// @input float rectLineWidth = 0.4 {"hint":"RECT ring thickness in cm. Uniform across every bubble, so all morphed rounded rects share the same line width regardless of bubble size."}'
    - "// @input float fillOpacity = 0.9 {\"hint\":\"Opacity multiplier for the ring fill (needs a translucent material to show). Matches the prototype's 0.9 fill opacity.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Morph Control (debug)</span>"}'
    - '// @input float globalProgress {"hint":"Morph amount applied to all bubbles when Auto Animate is off (0 = blob, 1 = rounded rect)"}'
    - '// @input bool autoAnimate = true {"hint":"Continuously oscillate the morph 0 <-> 1 for testing"}'
    - '// @input float animateSpeed = 1 {"hint":"Oscillation speed (radians per second) when Auto Animate is on"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Camera & Performance</span>"}'
    - '// @input SceneObject cameraObject {"hint":"The player camera object. Used to billboard bubbles toward the viewer and to cull off-screen updates. If unset, billboarding and FOV culling are disabled."}'
    - '// @input bool billboard = true {"hint":"Billboard each bubble to face the camera. Applied ONCE when the bubble spawns (its +Z normal is aimed at the camera position) and then held — the bubbles are world-fixed, so re-orienting every frame is wasted work."}'
    - "// @input bool fovCullEnabled = true {\"hint\":\"Skip per-frame mesh updates for bubbles outside the camera's field of view (they freeze until they come back into view).\"}"
    - '// @input float fovCullHalfAngleDeg = 70 {"hint":"Half-angle (degrees) of the view cone used for FOV culling. Generous values avoid culling bubbles near the screen edges; lower to cull more aggressively."}'
    - "// @input bool halfRateUpdate = true {\"hint\":\"Update only half the bubbles each frame (alternating halves), halving per-frame mesh compute. Wobble stays smooth because the skipped frame's time is folded into the next update.\"}"
    - '// @input bool logPerfStats {"hint":"Write a once-per-second report (bubble count, advances/frame, culled/frame, and time spent in the update loop) so you can verify FOV culling and half-rate updates are actually reducing work."}'
    - '// @input Component.Text perfStatsText {"hint":"Text component the perf report is written to. If unset, the report falls back to the console."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
    - '// @input bool enableLoggingLifecycle {"hint":"Enable lifecycle logging (onAwake, onStart, onUpdate, onDestroy)"}'
