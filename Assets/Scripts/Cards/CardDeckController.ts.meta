  ScriptTypes:
    -
      {}
  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">CardDeckController – the flat plane of premade cards above the globe</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Spawns the PremadeCard prefab per cardDeckData entry, registers each in global.cropCardStore, and lays them out clustered by relevance.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Asset.ObjectPrefab cardPrefab {"hint":"The PremadeCard prefab, instantiated once per deck entry as a child of this object."}'
    - '// @input Asset.Texture[] placeholderImages {"hint":"Placeholder image textures, assigned to the cards in order (cycled if fewer than the deck size). Fill the real images in later."}'
    - '// @input SceneObject cameraObject {"hint":"Camera the cards billboard toward + use for gaze. Forwarded to each spawned card."}'
    - '// @input AssignableType globeView {"hint":"GlobeView whose top surface point anchors the plane. If unset, Center Object (or this object) is used."}'
    - '// @input SceneObject centerObject {"hint":"Fallback anchor for the plane when no GlobeView is set."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Wrap placement (cylinder around the head)</span>"}'
    - "// @input float cardDistanceCm {\"hint\":\"Radius (cm) of the cylinder the cards wrap on = how far the cards are from your head. 0 = auto (the globe's distance). Independent of card size now — size is the image width below; push this out to move the whole field farther away.\"}"
    - '// @input float cardDistanceVariationCm = 30 {"hint":"Per-card depth spread (cm) by size: the BIGGEST card sits this much CLOSER than the cylinder radius and the SMALLEST this much FARTHER (a card mid-range stays on the radius). 0 = every card on the same cylinder. Size = its image-width multiplier (min/max below)."}'
    - '// @input float verticalCenterRiseCm = 20 {"hint":"How far (cm) ABOVE the globe top the field is vertically centred."}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Cylinder wall (wraps around the head, above the globe)</span>"}'
    - '// @input float canvasHeightCm = 20 {"hint":"Fixed HEIGHT (cm) of the cylinder-wall band. Vertical extent is fixed; cards spread sideways as needed to avoid overlap."}'
    - "// @input float cardGapCm {\"hint\":\"Extra spacing (cm) kept between cards on top of each card's REAL measured footprint. THE spacing knob now — raise it to spread cards apart, 0 = cards packed just shy of touching.\"}"
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Card size = the displayed IMAGE WIDTH; the picture, caption wrap, and auto-fit border all follow from it. The card root stays at its authored scale (no root shrinking).</span>"}'
    - "// @input float cardImageWidthCm = 3 {\"hint\":\"Base displayed image width for each card; height follows the image aspect, and the caption + auto-fit border size around it. THE size knob (smaller = smaller cards). The prefab's ImageAnchor scales the picture ~10x, so the on-screen card is larger than this raw number. Each card varies by its random multiplier (min/max below). NOTE: set this in the Inspector (editing the code default does nothing once the component is in the scene).\"}"
    - '// @input float cardSizeMinScale = 0.3 {"hint":"Smallest per-card size multiplier (variety): multiplies the base image width. Each card picks a random factor between this and the max."}'
    - '// @input float cardSizeMaxScale = 1 {"hint":"Largest per-card size multiplier (variety): multiplies the base image width."}'
    - "// @input float cardWidthCm = 10 {\"hint\":\"FALLBACK card footprint WIDTH (cm), used only for a card that hasn't measured its real size (e.g. border auto-fit off). Measured cards ignore this.\"}"
    - "// @input float cardHeightCm = 15 {\"hint\":\"FALLBACK card footprint HEIGHT (cm), used only for a card that hasn't measured its real size. Measured cards ignore this.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Gaze focus (cards near your view centre grow)</span>"}'
    - "// @input bool gazeScaleEnabled = true {\"hint\":\"Grow resting cards that fall within a cone around the camera's view centre, biggest at the centre.\"}"
    - '// @input float gazeScaleConeDeg = 18 {"hint":"Half-angle (degrees) of the gaze cone around the view centre. Cards inside it grow; cards outside stay at their resting size."}'
    - '// @input float gazeScaleMaxBoost = 1.6 {"hint":"Scale multiplier applied to the card EXACTLY at the view centre (1 = no growth). Falls off smoothly to 1 at the cone edge."}'
    - '// @input float gazeScaleEaseRate = 8 {"hint":"How quickly a card eases to its gaze-target size (higher = snappier)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Relevance (clustering)</span>"}'
    - '// @input float topicWeight = 0.7 {"hint":"Weight of shared topics in the relevance score (primary signal)."}'
    - '// @input float locationWeight = 0.2 {"hint":"Weight of same-location in the relevance score."}'
    - '// @input float dateWeight = 0.1 {"hint":"Weight of capture-date closeness in the relevance score."}'
    - '// @input float dateRangeDays = 120 {"hint":"Date span (days) over which closeness fades to zero — dates farther apart than this count as unrelated in time."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Gentle motion</span>"}'
    - '// @input float swayAmplitudeCm = 1.2 {"hint":"In-place sway amplitude (cm). Keep small so cards never drift into each other."}'
    - '// @input float swayFreqMin = 0.3 {"hint":"Slowest sway frequency (radians/sec)."}'
    - '// @input float swayFreqMax = 0.7 {"hint":"Fastest sway frequency (radians/sec)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Query results (driven by CardQueryVoiceAgent)</span>"}'
    - "// @input float searchSpinMultiplier = 3.5 {\"hint\":\"While the agent is searching, the gentle sway is sped up by this factor to signal 'working on it'.\"}"
    - '// @input float resultRowDepthCm = 45 {"hint":"Distance (cm) in front of the camera the result deck is placed. Keep this CLOSER than the plane so results read in front."}'
    - "// @input float resultRowRiseCm {\"hint\":\"Vertical offset (cm) of the result row relative to the camera's eye line (positive = up).\"}"
    - "// @input float resultCardSize = 0.5 {\"hint\":\"Uniform WORLD SCALE the CENTRED result card renders at; side cards shrink from this. (Overrides each card's varied deck size; restored when it returns to the cosmos.)\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">CoverFlow (result navigation)</span>"}'
    - '// @input float coverCenterGapCm = 14 {"hint":"Horizontal gap (cm) from the centred card to the FIRST card on each side."}'
    - '// @input float coverSideSpacingCm = 6 {"hint":"Horizontal spacing (cm) between successive side cards as they stack outward."}'
    - '// @input float coverDepthStepCm = 6 {"hint":"How far back (cm) each step from centre recedes — gives the side cards parallax depth."}'
    - '// @input float coverFoldStartDeg = 45 {"hint":"Fold angle (deg) of the FIRST card on each side, turned toward the centre."}'
    - '// @input float coverFoldStepDeg = 12 {"hint":"Extra fold (deg) added per further step away from centre."}'
    - '// @input float coverMaxFoldDeg = 75 {"hint":"Maximum fold angle (deg) any side card reaches."}'
    - '// @input float coverSideScaleFalloff = 0.82 {"hint":"Per-step scale falloff for side cards (0..1): each step from centre multiplies size by this."}'
    - '// @input float coverMinScaleFrac = 0.4 {"hint":"Smallest scale fraction a far side card shrinks to (× the centred size)."}'
    - '// @input float coverMaxVisiblePerSide = 6 {"hint":"Cards farther than this many steps from centre stack at the edge instead of spreading further."}'
    - '// @input float coverScrubStepCm = 12 {"hint":"Hand travel (cm) along the row required to scrub one card while pinch-dragging."}'
    - '// @input float coverSnapRate = 12 {"hint":"How crisply the deck settles to the centred card after release (higher = snappier)."}'
    - '// @input float coverFlickThreshold = 25 {"hint":"Release hand speed (cm/s) above which a quick flick advances one extra card in that direction."}'
    - '// @input bool coverInvertScrub {"hint":"Invert the pinch-drag direction (which way you move your hand for next vs. previous)."}'
    - '// @input bool coverInvertFold {"hint":"Invert the side-card fold direction (which way left/right cards tilt)."}'
    - "// @input float coverVGapFrac = 0.5 {\"hint\":\"Vertical browse deck: top/bottom card centre offset as a FRACTION of the centred card's height. Lower = more tucked/overlapping (deck); higher = more separated.\"}"
    - '// @input float coverVStepFrac = 0.6 {"hint":"Vertical browse deck: extra offset (fraction of card height) for the transient incoming card beyond the edge."}'
    - '// @input float coverVFoldDeg = 65 {"hint":"Vertical browse deck: resting tilt (deg) of the top/bottom card. Steep so it foreshortens into a peeking sliver (Cover Flow look)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - // @input bool enableLogging
    - // @input bool enableLoggingLifecycle
