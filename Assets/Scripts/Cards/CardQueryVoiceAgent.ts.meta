  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Card Query Voice Agent (Gemini Live + tools)</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Listens in the cosmos view, extracts query keywords via function-calling, drives the deck + globe, then discusses results. Does NOT run in the simulator — test on device with internet.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Setup (drag from the RemoteServiceGatewayExamples prefab)"}'
    - "// @input SceneObject websocketRequirementsObj {\"hint\":\"The 'Websocket requirements' SceneObject. Enabled on first listen so the gateway WebSocket can connect.\"}"
    - "// @input AssignableType dynamicAudioOutput {\"hint\":\"A DEDICATED DynamicAudioOutput for this agent's voice (not shared with CardVoiceAgent/WelcomeVoice).\"}"
    - "// @input AssignableType_1 microphoneRecorder {\"hint\":\"A DEDICATED MicrophoneRecorder that captures the user's spoken query.\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Scene references"}'
    - '// @input AssignableType_2 cardDeck {"hint":"The CardDeckController whose cosmos this agent drives (spin/results/focus)."}'
    - '// @input AssignableType_3 globeController {"hint":"The GlobeController to zoom on a result location. If unset, global.globeController is used."}'
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Activation"}'
    - '// @input bool autoStart = true {"hint":"Automatically arm the mic when the user gazes at the deck (and the deck is in the scene). Off = start only via beginListening()."}'
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Speech"}'
    - '// @input string voice = "Aoede" {"widget":"combobox", "values":[{"label":"Leda", "value":"Leda"}, {"label":"Puck", "value":"Puck"}, {"label":"Charon", "value":"Charon"}, {"label":"Kore", "value":"Kore"}, {"label":"Fenrir", "value":"Fenrir"}, {"label":"Aoede", "value":"Aoede"}, {"label":"Orus", "value":"Orus"}, {"label":"Zephyr", "value":"Zephyr"}]}'
    - '// @input string persona {"hint":"System instruction / persona for the query agent.", "widget":"text_area"}'
    - "// @input string model = \"gemini-live-2.5-flash\" {\"hint\":\"Gemini Live model id (no 'models/' prefix). Supported: gemini-live-2.5-flash, gemini-2.0-flash-live-preview-04-09, gemini-live-2.5-flash-preview-native-audio\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
