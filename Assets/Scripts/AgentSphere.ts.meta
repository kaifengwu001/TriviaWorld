  InputLines:
    - "// @ui {\"widget\":\"label\", \"label\":\"<span style=\\\"color: #60A5FA;\\\">AgentSphere – the voice agent's visual presence</span><br/><span style=\\\"color: #94A3B8; font-size: 11px;\\\">A small orb that head-follows the user and travels between the panel, a home corner of the FOV, and the active card. Driven by the voice scripts via global.agentSphere.</span>\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Scene References</span>"}'
    - "// @input SceneObject cameraObj {\"hint\":\"Head camera object (wire the 'Camera Object'). Used as the frame for FOV-relative positions.\"}"
    - '// @input SceneObject sphereObj {"hint":"The orb whose world transform is driven (a small sphere visual)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Placement (fraction of half-FOV: x -1=left..+1=right, y -1=bottom..+1=top)</span>"}'
    - '// @input vec2 panelScreenPos = {0.5,0.5} {"hint":"Panel state: top-right of the FOV (in front of the panel), matching the card-perch corner. Lower magnitudes pull it toward center if the device crops it."}'
    - '// @input float panelDepth = 120 {"hint":"Distance (cm) for the panel state. The interest panel sits ~140cm out; keep this a bit in front of it."}'
    - '// @input vec2 homeScreenPos = {0.55,-0.55} {"hint":"Home state: bottom-right of the FOV. Lower magnitudes keep it more centered / safely on-screen."}'
    - '// @input float homeDepth = 55 {"hint":"Distance (cm) for the home state."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Perch offsets (cm — shared by the card and panel top-right corner)</span>"}'
    - '// @input float cardPadRight = 3 {"hint":"How far past the right edge to sit."}'
    - '// @input float cardPadUp = 3 {"hint":"How far above the top edge to sit."}'
    - '// @input float cardPopOut = 3 {"hint":"How far to pop out toward the viewer off the surface plane (keeps the orb in front of the card / panel)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Motion</span>"}'
    - '// @input float moveSpeed = 4 {"hint":"Position follow speed (lerp factor = moveSpeed * dt). Lower = lazier, laggier follow."}'
    - '// @input float rotateSpeed = 4 {"hint":"Rotation follow speed for the yaw-only billboard (slerp factor = rotateSpeed * dt)."}'
    - '// @input float idleBob = 0.5 {"hint":"Amplitude (cm) of the subtle idle bob (folded into the target so it stays smooth)."}'
    - '// @input float speakPulse = 0.18 {"hint":"Extra scale fraction applied while the agent is speaking."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
