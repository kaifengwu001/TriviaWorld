  InputLines:
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">TopicSelectionPanel – launch-time interest picker</span><br/><span style=\"color: #94A3B8; font-size: 11px;\">Builds a honeycomb of toggleable CapsuleButtons under a Frame and commits the selection to the InterestStore on Start.</span>"}'
