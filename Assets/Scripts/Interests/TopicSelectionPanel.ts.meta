    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input AssignableType frame {"hint":"Frame component the buttons are spawned under (falls back to a Frame on this object)"}'
    - '// @input SceneObject cameraObj {"hint":"Camera used to position the panel in front of the user at launch (optional)"}'
    - '// @input AssignableType_1 interestStore {"hint":"InterestStore to commit selections to (falls back to global.cropInterestStore)"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Layout</span>"}'
    - '// @input string[] topics = {} {"hint":"Topics to show. Leave empty to use the editable DEFAULT_TOPICS list."}'
    - '// @input float ovalAspect = 1.6 {"hint":"Width/height ratio of the oval cluster. >1 is wider than tall. Drives how many rows are used."}'
    - '// @input float horizontalGap = 1.5 {"hint":"Horizontal gap between buttons (cm)"}'
    - '// @input float verticalGap = 1 {"hint":"Vertical gap between honeycomb rows (cm)"}'
    - '// @input float buttonDepthOffset = 1 {"hint":"How far the buttons sit in front of the frame plane to avoid clipping (cm)"}'
    - '// @input float labelSize = 28 {"hint":"Font size for the button labels"}'
    - '// @input string startLabel = "Start exploring" {"hint":"Label of the confirm button"}'
    - '// @input float distanceFromCamera = 60 {"hint":"Distance in cm to place the panel in front of the camera at launch"}'
    - '// @input vec3 panelOffset {"hint":"Offset (cm) of the buttons relative to the background frame: x=right, y=up, z=depth"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
