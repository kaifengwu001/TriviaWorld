  InputLines:
    - "// @ui {\"widget\":\"label\", \"label\":\"<span style=\\\"color: #60A5FA;\\\">AgentRing – the voice agent's animated circle</span><br/><span style=\\\"color: #94A3B8; font-size: 11px;\\\">Three additive CMY noisy discs that read as a white circle when quiet and bloom into colored fringes with voice amplitude. Reads global.agentSphere.getAudioLevel().</span>\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">References</span>"}'
    - '// @input Asset.Material baseMaterial {"hint":"Base material CLONED per layer (its baseColor/blend are overwritten — the asset is never mutated). Any unlit material works; an additive one is ideal."}'
    - '// @input SceneObject cameraObj {"hint":"Head camera object. Used to billboard the circle to fully face the viewer each frame. If unset, billboarding is disabled."}'
    - '// @input bool selfBillboard {"hint":"Self-billboard this ring each frame. Default OFF: the ring is normally a child of the object AgentSphere already billboards (yaw-only), so re-orienting here is redundant work. Turn on only if the ring is NOT parented under a billboarding AgentSphere."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Layer Colors (additive → white where they overlap)</span>"}'
    - "// @input vec4 color0 = {0,1,1,1}"
    - "// @input vec4 color1 = {1,0,1,1}"
    - "// @input vec4 color2 = {1,1,0,1}"
    - '// @input float colorIntensity = 0.7 {"hint":"Brightness multiplier applied to all three layer colors (additive blend can clip; lower this if the white core blows out)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Shape</span>"}'
    - '// @input float radius = 3 {"hint":"Ring outer radius in cm (local)."}'
    - "// @input float innerFraction = 0.12 {\"hint\":\"Ring band thickness as a fraction of the radius (the inner rim sits at radius*(1-this)). Small = thin ring; 1 = solid disc. Matches BubbleMesh's Inner Fraction.\"}"
    - '// @input float numPoints = 64 {"hint":"Rim points per ring. Higher = smoother circle, more CPU. 48–72 is a good range."}'
    - '// @input float noiseScale = 0.5 {"hint":"Perlin sampling scale — higher = more, tighter wobbles around the rim."}'
    - "// @input float zGap = 0.05 {\"hint\":\"Z gap (cm) between adjacent layers so the planes don't z-fight. Tiny is fine.\"}"
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Performance</span>"}'
    - '// @input bool staggerRingUpdates = true {"hint":"Stagger ring rebuilds (default ON): rebuild only ONE of the three discs per frame round-robin (each refreshes at ~20 Hz), cutting the per-frame mesh work to a third. Turn OFF to rebuild all three discs every frame (the pre-optimization behavior) — smoother undulation/color bloom at higher CPU cost."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Amplitude Response</span>"}'
    - '// @input float quietDistortion = 1.5 {"hint":"Rim distortion when quiet (small = nearly a clean circle)."}'
    - '// @input float loudDistortion = 7 {"hint":"Rim distortion at full amplitude (large = dramatic wobble)."}'
    - '// @input float quietSpeed = 0.15 {"hint":"Undulate speed (noise time advanced per second) when quiet."}'
    - '// @input float loudSpeed = 1.2 {"hint":"Undulate speed at full amplitude."}'
    - "// @input float divergence = 1.6 {\"hint\":\"How far the three layers' noise times drift apart at full amplitude. 0 = always matched (always white); higher = more colored fringe when loud.\"}"
    - '// @input float divergenceExponent = 1.5 {"hint":"Shapes the amplitude→divergence curve. 1 = linear; >1 keeps the circle whiter until the agent gets loud, then blooms color."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Eyes</span>"}'
    - '// @input bool showEyes = true {"hint":"Draw a pair of white dot eyes in the center of the ring."}'
    - '// @input vec4 eyeColor = {1,1,1,1} {"hint":"Eye color (RGBA). White reads as classic dot eyes."}'
    - '// @input float eyeSize = 0.4 {"hint":"Eye half-size in cm (the rect spans ±this in x/y; height is then scaled by the ratio below)."}'
    - '// @input float eyeAspect = 1 {"hint":"Eye height-to-width ratio. 1 = round dot; >1 = taller (oval); <1 = wider. Blinking scales the height further."}'
    - '// @input float eyeDistance = 1.6 {"hint":"Horizontal distance (cm) between the two eye centers."}'
    - '// @input float eyeHeight = 0.4 {"hint":"Vertical offset (cm) of the eyes from the ring center. Positive = higher."}'
    - '// @input float eyeForward = 0.5 {"hint":"How far to pop the eyes toward the viewer (cm) off the ring plane, so they sit in front of the ring. Larger = more forward."}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Blink (quick vertical squash)</span>"}'
    - '// @input float blinkIntervalMin = 2.5 {"hint":"Minimum seconds between blinks."}'
    - '// @input float blinkIntervalMax = 6 {"hint":"Maximum seconds between blinks."}'
    - '// @input float blinkDuration = 0.12 {"hint":"How long a single blink takes (seconds). ~0.1–0.15 looks natural."}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Dart (small saccade offsets)</span>"}'
    - '// @input float dartIntervalMin = 1.5 {"hint":"Minimum seconds between darts."}'
    - '// @input float dartIntervalMax = 4.5 {"hint":"Maximum seconds between darts."}'
    - '// @input float dartHold = 0.4 {"hint":"How long the eyes hold at a darted position before returning to center (seconds)."}'
    - '// @input float dartAmount = 0.25 {"hint":"Maximum dart offset in cm (kept small — these are subtle eye flicks)."}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Logging</span>"}'
    - '// @input bool enableLogging {"hint":"Enable general logging"}'
