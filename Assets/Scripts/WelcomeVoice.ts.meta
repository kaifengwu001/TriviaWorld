  InputLines:
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #60A5FA;\">Welcome Voice (Gemini Live + mic + tools)</span>"}'
    - '// @ui {"widget":"label", "label":"<span style=\"color: #94A3B8; font-size: 11px;\">Generative host that greets, listens, and selects topics + presses Start for the user by voice. Barges-in when the user speaks. Does NOT run in the simulator — test on device with internet.</span>"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Setup (drag from the RemoteServiceGatewayExamples prefab)"}'
    - "// @input SceneObject websocketRequirementsObj {\"hint\":\"The 'Websocket requirements' SceneObject from the RemoteServiceGatewayExamples prefab. Enabled on launch so the gateway WebSocket can connect.\"}"
    - "// @input AssignableType dynamicAudioOutput {\"hint\":\"The 'DynamicAudioOutput' object from the RemoteServiceGatewayExamples prefab (it carries the AudioComponent + audio-output track that plays the voice).\"}"
    - "// @input AssignableType_1 microphoneRecorder {\"hint\":\"A MicrophoneRecorder that captures the user's speech (can be shared with the RecommendationVoiceAgent — they never run at once).\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Speech"}'
    - '// @input string voice = "Leda" {"widget":"combobox", "values":[{"label":"Leda", "value":"Leda"}, {"label":"Puck", "value":"Puck"}, {"label":"Charon", "value":"Charon"}, {"label":"Kore", "value":"Kore"}, {"label":"Fenrir", "value":"Fenrir"}, {"label":"Aoede", "value":"Aoede"}, {"label":"Orus", "value":"Orus"}, {"label":"Zephyr", "value":"Zephyr"}]}'
    - "// @input string greetingText = \"Warmly welcome the user to TriviaGo. Say you're excited to learn and explore the world together with them. Then invite them to tell you what kinds of things they're curious about, so you can set up their topics. Keep it to about two short, natural sentences.\" {\"hint\":\"What the launch greeting should convey (the model says it in its own words, so wording varies).\", \"widget\":\"text_area\"}"
    - '// @input float delaySeconds = 5 {"hint":"Seconds after launch before the welcome greeting"}'
    - '// @input float listenDelaySeconds = 7 {"hint":"Seconds after launch before the host starts LISTENING (opening the mic). Deferred past the Connected Lenses session spin-up at launch, which otherwise yields a silent mic. Keep it at/after the greeting delay."}'
    - "// @input string hostPersona = \"You are the warm, upbeat first-person voice host of TriviaGo, an AR learning companion, talking with the user as they look at a panel of topic buttons. Your job is to help them pick the topics they're curious about and then start. LISTEN and respond naturally — never read instructions back, no stage directions or quotation marks. As soon as the user mentions interests, call select_topics with the matching topic names (map loose phrasing like 'science' or 'space stuff' to the closest available topics), then briefly confirm what you selected and ask if they'd like to add anything else or are ready to start. If they want to remove a topic, call deselect_topics. When the user says they're ready (or to go ahead / start), call start_exploring. Don't start until they've confirmed. Keep every reply to one or two short, friendly sentences, and vary your wording.\" {\"hint\":\"Host persona / system instruction. The model converses naturally and drives the topic panel through its tools.\", \"widget\":\"text_area\"}"
    - "// @input string model = \"gemini-live-2.5-flash\" {\"hint\":\"Gemini Live model id (no 'models/' prefix — it's added automatically). Supported: gemini-live-2.5-flash, gemini-2.0-flash-live-preview-04-09, gemini-live-2.5-flash-preview-native-audio\"}"
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"separator"}'
    - '// @ui {"widget":"group_start", "label":"Logging"}'
    - // @input bool enableLogging = true
    - '// @ui {"widget":"group_end"}'
