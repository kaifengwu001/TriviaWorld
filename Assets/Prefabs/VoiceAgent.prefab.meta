- !<ScriptComponent/77d2c357-de28-4edf-7820-fe5195f9879f>
  PrefabRemaps:
    []
  Name: CardVoiceAgent
  Enabled: true
  ScriptAsset: !<reference> f51d6fb4-bf91-4bb4-8bc5-b31b89cc21ac
  ScriptInputsDefault:
    voice: true
    model: true
    enableLogging: true
  ScriptTypesDefault:
    {}
  ScriptInputs:
    "":
      websocketRequirementsObj: !<reference.SceneObject> 9e699c2a-7957-4e80-7e3d-d6c8eccec7dc
      dynamicAudioOutput: !<MappingBased.AssignableType> ebcf5c8e-dd2a-444e-a061-7b383eed8b7e
      microphoneRecorder: !<MappingBased.AssignableType_1> 435a158d-ddca-4b73-55b3-c177f477f1b5
      voice: Leda
      persona: |
        You are a warm, patient, encouraging teacher/mentor/museum-guide voice for an AR trivia lens. The user explores cards, each showing an interesting fact. When given a card's context, add ONE extra specific,accurate detail related to it (never just repeat the caption), then invite them to ask anything. Answer follow-up questions conversationally in one to three sentences, staying on that card's subject unless theuser changes topic. Stay accurate; if you are unsure, say so briefly.

      model: gemini-live-2.5-flash
      enableLogging: true
  ScriptTypes:
    "":
      {}
